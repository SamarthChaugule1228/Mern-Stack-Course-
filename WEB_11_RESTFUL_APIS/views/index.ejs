<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts</title>
    <link rel="stylesheet" href="./style.css">
</head>
<body>
    <h1>Quora Posts </h1>
    <%for( let post of posts) {%>
    <div>
        <h3><%= post.username%></h3>
        <h3><%= post.content%></h3>
        <a href="http://localhost:3000/posts/<%=post.id%>"> <b>See Details</b></a>
        <a href="http://localhost:3000/posts/<%=post.id%>/edit"> <b>Edit Post</b> </a>
        <form action="/posts/id<%=post.id%>?_method=DELETE" method="post">
            <button>Delete</button>
        </form>
    </div>
    <%}%>
    <a href="http://localhost:3000/posts/newpost"> Create Post </a>
    
</body>
</html>