<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Your Chat</title>
</head>
<body>
    <h1>Edit Your Chat :  <%= chat.id %></h1>

    <p> this chat was sent from <%= chat.from %> to <%= chat.to %></p>
    <form method="POST" action="/chats/<%=chat._id %>?_method=put">
        <textarea name="msg" rows="5" cols="10" placeholder="Enter Your Message....."><%= chat.msg %></textarea>
        <button>Edit </button>
    </form>
</body>
</html>